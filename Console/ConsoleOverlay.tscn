[gd_scene format=3 uid="uid://cjrqaluoorc6f"]

[sub_resource type="GDScript" id="GDScript_f7nh6"]
resource_name = "ConsoleOverlay"
script/source = "extends CanvasLayer

signal command_submitted(command_text: String)

@onready var input_field: LineEdit = $ColorRect/VBoxContainer/MarginContainer/InputField
@onready var output_scroll: ScrollContainer = $ColorRect/VBoxContainer/ScrollContainer
@onready var output_label: Label = $ColorRect/VBoxContainer/ScrollContainer/MarginContainer/Label


func _ready() -> void:
    visible = false


func show_console() -> void:
    visible = true
    input_field.grab_focus()


func hide_console() -> void:
    visible = false


func toggle_console() -> void:
    if visible:
        hide_console()
    else:
        show_console()


func is_console_visible() -> bool:
    return visible


func append_output_line(text: String) -> void:
    append_output(text + \"\\n\")


func append_output(text: String) -> void:
    output_label.text += text
    call_deferred(\"_scroll_to_bottom\")


func _scroll_to_bottom() -> void:
    output_scroll.scroll_vertical = int(output_scroll.get_v_scroll_bar().max_value)


func clear_output() -> void:
    output_label.text = \"\"


func _on_input_field_text_submitted(command_text: String) -> void:
    command_submitted.emit(command_text)
    input_field.clear()
"

